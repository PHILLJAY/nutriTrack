generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  discordId       String?  @unique
  name            String
  age             Int
  gender          String
  height          Float
  weight          Float
  activityLevel   String
  goal            String
  targetCalories  Int
  targetProtein   Float
  targetCarbs     Float
  targetFat       Float
  timezone        String   @default("UTC")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  meals           Meal[]
  mealTemplates   MealTemplate[]
  waterEntries    WaterEntry[]
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  glasses   Int
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())
}

model MealTemplate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sugar        Float?
  sodium       Float?
  mealType     String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Meal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  name         String
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sugar        Float?
  sodium       Float?
  healthRating Int
  mealType     String
  eatenAt      DateTime
  notes        String?
  source       String
  imageId      String?
  image        Image?    @relation(fields: [imageId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Image {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  meals     Meal[]
}
