// ============================================================================
// PostgreSQL Migration Path
// ============================================================================
// To switch to PostgreSQL (recommended for production on Railway/Neon/Supabase):
//
// 1. Change the datasource block:
//    datasource db {
//      provider = "postgresql"
//      url      = env("DATABASE_URL")
//    }
//
// 2. Set DATABASE_URL in .env:
//    DATABASE_URL="postgresql://user:password@host:5432/nutritrack?schema=public"
//
// 3. Run migration:
//    npx prisma migrate dev --name switch_to_postgresql
//
// All models use cuid() for IDs, which is compatible with both SQLite and PostgreSQL.
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  discordId       String?  @unique
  name            String
  age             Int
  gender          String
  height          Float
  weight          Float
  activityLevel   String
  goal            String
  targetCalories  Int
  targetProtein   Float
  targetCarbs     Float
  targetFat       Float
  targetProteinPct Float?
  targetCarbsPct   Float?
  targetFatPct     Float?
  timezone        String   @default("UTC")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  meals           Meal[]
  mealTemplates   MealTemplate[]
  waterEntries    WaterEntry[]
  weightEntries   WeightEntry[]
  groceryLists    GroceryList[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  weight    Float
  date      String
  notes     String?
  createdAt DateTime @default(now())
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  glasses   Int
  date      String
  createdAt DateTime @default(now())
}

model MealTemplate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sugar        Float?
  sodium       Float?
  mealType     String
  notes        String?
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Meal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  name         String
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float?
  sugar        Float?
  sodium       Float?
  vitaminA     Float?
  vitaminC     Float?
  vitaminD     Float?
  calcium      Float?
  iron         Float?
  healthRating Int
  mealType     String
  eatenAt      DateTime
  notes        String?
  source       String
  imageId      String?
  image        Image?    @relation(fields: [imageId], references: [id])
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Image {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  meals     Meal[]
}

model GroceryList {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  name      String
  items     GroceryItem[]
  createdAt DateTime      @default(now())
}

model GroceryItem {
  id        String      @id @default(cuid())
  listId    String
  list      GroceryList @relation(fields: [listId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  unit      String?
  checked   Boolean     @default(false)
  createdAt DateTime    @default(now())
}
